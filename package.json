{
  "name": "@chubbyts/chubbyts-framework-skeleton",
  "description": "A minimal skeleton for chubbyts-framework.",
  "type": "module",
  "keywords": [
    "chubbyts",
    "framework",
    "skeleton"
  ],
  "author": "Dominik Zogg",
  "license": "MIT",
  "repository": "chubbyts/chubbyts-framework-skeleton",
  "scripts": {
    "build": "rm -Rf dist && tsc",
    "command": "tsx bin/console.ts",
    "cs-fix": "prettier --write bin bootstrap config src tests *.js *.ts",
    "cs": "prettier --check bin bootstrap config src tests *.js *.ts",
    "develop:debug": "tsx watch --inspect=0.0.0.0:8888 bootstrap/index.ts",
    "develop": "tsx watch bootstrap/index.ts",
    "infection": "stryker run",
    "lint-fix": "eslint bin bootstrap config src tests *.js *.ts --fix",
    "lint": "eslint bin bootstrap config src tests",
    "start:debug": "pnpm install && pnpm run lint-fix && pnpm run cs-fix && pnpm run develop:debug",
    "start": "pnpm install && pnpm run lint-fix && pnpm run cs-fix && pnpm run develop",
    "test:integration": "vitest --config vitest.integration.config.js",
    "test": "vitest --config vitest.config.js"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@chubbyts/chubbyts-dic": "^2.1.1",
    "@chubbyts/chubbyts-dic-config": "^2.1.1",
    "@chubbyts/chubbyts-dic-types": "^2.1.1",
    "@chubbyts/chubbyts-framework": "3.1.2",
    "@chubbyts/chubbyts-framework-router-path-to-regexp": "3.1.2",
    "@chubbyts/chubbyts-http-error": "^3.2.1",
    "@chubbyts/chubbyts-log-types": "^3.1.1",
    "@chubbyts/chubbyts-pino-adapter": "^3.1.1",
    "@chubbyts/chubbyts-undici-server": "^1.1.2",
    "@chubbyts/chubbyts-undici-server-node": "^1.1.2",
    "commander": "^14.0.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@chubbyts/chubbyts-eslint": "^5.1.1",
    "@chubbyts/chubbyts-function-mock": "^2.1.1",
    "@prettier/sync": "^0.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-fetch": "^4.1.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
